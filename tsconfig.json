{
	"compilerOptions": {
		"target": "ES2020",
		"useDefineForClassFields": true,
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ES2020", "DOM"],
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true,
		"types": ["vitest/globals"]
	},
	"include": ["src", "test", "vite.config.ts"]
}
